#!/bin/bash
# ============================================================
# Russian Phonetic Max - postinstall Script
# Runs as root after the Installer places files.
# Every step guarded with || true so postinstall never fails.
# ============================================================

SYS_KB="/Library/Keyboard Layouts"
BUNDLE_NAME="Russian-Phonetic-Max.bundle"
KEYLAYOUT_NAME="Russian-Phonetic-Max.keylayout"

# Determine the real console user (not root)
CONSOLE_USER=$(stat -f '%Su' /dev/console 2>/dev/null) || CONSOLE_USER=""
if [ -z "$CONSOLE_USER" ] || [ "$CONSOLE_USER" = "root" ]; then
    CONSOLE_USER=$(echo "show State:/Users/ConsoleUser" | scutil | awk '/Name :/ { print $3 }') || true
fi
CONSOLE_HOME=$(dscl . -read "/Users/$CONSOLE_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}') || true
USR_KB="$CONSOLE_HOME/Library/Keyboard Layouts"

echo "postinstall: Console user=$CONSOLE_USER, home=$CONSOLE_HOME"

# ── [1] Fix permissions: 755 dirs, 644 files, root:wheel ─────────────────────
echo "postinstall [1/8]: Permissions setzen..."
chown -R root:wheel "$SYS_KB/$BUNDLE_NAME"           || true
find "$SYS_KB/$BUNDLE_NAME" -type d -exec chmod 755 {} + || true
find "$SYS_KB/$BUNDLE_NAME" -type f -exec chmod 644 {} + || true
chown root:wheel "$SYS_KB/$KEYLAYOUT_NAME"            || true
chmod 644 "$SYS_KB/$KEYLAYOUT_NAME"                    || true

# ── [2] Remove quarantine ─────────────────────────────────────────────────────
echo "postinstall [2/8]: Quarantaene entfernen..."
xattr -cr "$SYS_KB/$BUNDLE_NAME"                      || true
xattr -cr "$SYS_KB/$KEYLAYOUT_NAME"                   || true

# ── [3] Remove old user-level layouts ─────────────────────────────────────────
echo "postinstall [3/8]: Alte User-Layouts entfernen..."
if [ -n "$CONSOLE_HOME" ] && [ "$USR_KB" != "$SYS_KB" ] && [ -d "$USR_KB" ]; then
    rm -rf "$USR_KB/Russian-Phonetic-Max.bundle"       || true
    rm -f  "$USR_KB/Russian-Phonetic-Max.keylayout"    || true
    rm -f  "$USR_KB/Russian-MB.keylayout"              || true
    rm -f  "$USR_KB/Russian-MB.keylayout.disabled"     || true
    rm -rf "$USR_KB/Russian Keyboard MB.bundle"        || true
fi

# ── [4] Copy to ~/Library/Keyboard Layouts (macOS 26 compatibility) ──────────
echo "postinstall [4/8]: User-Kopie fuer macOS 26..."
if [ -n "$CONSOLE_HOME" ] && [ "$USR_KB" != "$SYS_KB" ] && [ -n "$CONSOLE_USER" ]; then
    mkdir -p "$USR_KB"                                 || true
    cp -R "$SYS_KB/$BUNDLE_NAME" "$USR_KB/"           || true
    cp "$SYS_KB/$KEYLAYOUT_NAME" "$USR_KB/"           || true
    # Fix ownership to real user
    CONSOLE_GID=$(id -g "$CONSOLE_USER" 2>/dev/null)   || CONSOLE_GID="staff"
    chown -R "$CONSOLE_USER:$CONSOLE_GID" "$USR_KB/$BUNDLE_NAME"    || true
    chown "$CONSOLE_USER:$CONSOLE_GID" "$USR_KB/$KEYLAYOUT_NAME"    || true
fi

# ── [5] Clear HIToolbox cache ────────────────────────────────────────────────
echo "postinstall [5/8]: HIToolbox-Cache leeren..."
if [ -n "$CONSOLE_HOME" ]; then
    sudo -u "$CONSOLE_USER" defaults delete com.apple.HIToolbox AppleEnabledInputSources  2>/dev/null || true
    sudo -u "$CONSOLE_USER" defaults delete com.apple.HIToolbox AppleSelectedInputSources 2>/dev/null || true
    sudo -u "$CONSOLE_USER" defaults delete com.apple.HIToolbox AppleInputSourceHistory   2>/dev/null || true
fi

# ── [6] Clean com.apple.inputsources.plist ───────────────────────────────────
echo "postinstall [6/8]: inputsources.plist bereinigen..."
if [ -n "$CONSOLE_HOME" ]; then
    IS_PLIST="$CONSOLE_HOME/Library/Preferences/com.apple.inputsources.plist"
    /usr/libexec/PlistBuddy -c "Delete :AppleSelectedInputSources" "$IS_PLIST" 2>/dev/null || true
    /usr/libexec/PlistBuddy -c "Delete :AppleEnabledInputSources"  "$IS_PLIST" 2>/dev/null || true
fi

# ── [7] Clear IntlDataCache ──────────────────────────────────────────────────
echo "postinstall [7/8]: IntlDataCache leeren..."
find /var/folders -name "com.apple.IntlDataCache*" -delete 2>/dev/null || true

# ── [8] TIS live-register ────────────────────────────────────────────────────
echo "postinstall [8/8]: TIS live-register..."
swift -e "
import Carbon
let url = URL(fileURLWithPath: \"$SYS_KB/$KEYLAYOUT_NAME\")
let s = TISRegisterInputSource(url as CFURL)
print(\"TIS Register bare keylayout: \(s == 0 ? \"OK\" : \"Error \(s)\")\")
" 2>/dev/null || true

swift -e "
import Carbon
let url = URL(fileURLWithPath: \"$SYS_KB/$BUNDLE_NAME\")
let s = TISRegisterInputSource(url as CFURL)
print(\"TIS Register bundle: \(s == 0 ? \"OK\" : \"Error \(s)\")\")
" 2>/dev/null || true

echo "postinstall: Fertig."
exit 0
